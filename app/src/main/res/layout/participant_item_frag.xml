<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="vertical"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="10dp"
        >
        <ImageView
            android:id="@+id/avatar_url"
            android:layout_width="40dp"
            android:layout_height="40dp"

            android:padding="8dp"
            android:layout_marginVertical="10dp"
            android:src="@drawable/iconstack_io____user_"
            android:background="@drawable/profile_form_circle"
            android:backgroundTint="@color/emerald500"
            />

        <TextView
            android:id="@+id/participant_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"

            android:maxWidth="200dp"
            android:layout_weight="1"
            android:text="Maksatbek"
            android:textSize="18sp"

            />
        <ImageButton
            android:id="@+id/mic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/iconstack_io____mic_"

            />
        <ImageButton
            android:id="@+id/video"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/iconstack_io____video_camera_"

            />

    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@color/gray_100"/>

</LinearLayout>
