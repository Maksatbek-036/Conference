<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/card_button">
<ImageView
    android:id="@+id/o_clock"
    android:layout_width="40dp"
    android:layout_height="35dp"
    android:layout_margin="10dp"
    android:padding="5dp"
    android:src="@drawable/iconstack_io____clock_"
    android:background="@drawable/card_image_hover"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"

    />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="250dp"
        android:layout_height="wrap_content"

        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="13dp"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@+id/o_clock"
       >

        <TextView
            android:id="@+id/list_plans_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:textStyle="bold"
            android:textSize="18dp"
            android:maxWidth="150dp"
            android:text="Команда разработки вв" />

        <TextView
            android:id="@+id/list_plans_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:maxWidth="240dp"
            android:text="Сегодня,12:00" />
        <TextView
            android:id="@+id/list_plans_identifity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:maxWidth="240dp"
            android:text="@string/app_name" />

    </LinearLayout>

    <Button
        android:id="@+id/start_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Начать"
        android:backgroundTint="@color/emerald600"
        android:textColor="@color/emerald500"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/linearLayout"
        app:layout_constraintTop_toTopOf="parent" />




</androidx.constraintlayout.widget.ConstraintLayout>