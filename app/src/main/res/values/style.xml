<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Button.Green.Hover" parent="Widget.AppCompat.ImageButton">
        <item name="android:backgroundTint">@color/emerald600</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="Widget.Button.Gray" parent="Widget.AppCompat.ImageButton">
        <item name="android:backgroundTint">@color/gray_500</item>
        <item name="android:background">@drawable/icons_form_circle</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="EditText">
        <item name="android:background">@drawable/edittext_background</item>
        <item name="android:textColor">@color/gray_700</item>
    </style>


    <style name="Widget.Button.Green" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/icon_form_circle</item>
        <item name="android:backgroundTint">#00000000</item>

        <item name="android:textColor">@color/emerald500</item>
    </style>

    <!-- Красная кнопка (выход/ошибка) -->
    <style name="ParticipantCard">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:backgroundTint">@color/gray_50</item>
        <item name="strokeColor">@color/red</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="OutgoingMessageStyle">
        <item name="android:background">@drawable/bg_outgoing</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="IncomingMessageStyle">
        <item name="android:background">@drawable/bg_incoming</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">16sp</item>
    </style>
    <!-- styles.xml -->

        <style name="EmeraldButton" >
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">60dp</item>

            <item name="android:backgroundTint">@color/emerald500</item>
            <item name="android:textSize">20sp</item>
            <item name="cornerRadius">15dp</item>
        </style>
    <style name="GreenEditText" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>


        <item name="android:background">@drawable/edittext_background</item>
       <item name="android:textColor">@color/gray_700</item>
        <item name="android:padding">10dp</item>
    </style>


</resources>